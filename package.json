{
  "name": "pccl",
  "private": true,
  "scripts": {
    "dev": "pnpm infra:up && turbo run dev",
    "infra:up": "docker compose -f infra/docker/compose/docker-compose.dev.yml up -d --wait",
    "infra:down": "docker compose -f infra/docker/compose/docker-compose.dev.yml down",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22"
  }
}
