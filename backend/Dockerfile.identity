FROM node:20-alpine AS builder
WORKDIR /app
COPY package.json package-lock.json* tsconfig.json nest-cli.json ./
COPY apps/identity-service ./apps/identity-service
COPY libs ./libs
RUN npm ci --no-audit --no-fund
RUN npx prisma generate --schema=apps/identity-service/prisma/schema.prisma
RUN npx nest build identity-service

FROM node:20-alpine
WORKDIR /app
COPY --from=builder /app/package.json ./
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/dist/apps/identity-service ./dist/apps/identity-service
COPY --from=builder /app/apps/identity-service/prisma ./apps/identity-service/prisma
COPY --from=builder /app/apps/identity-service/src/prisma/generated ./apps/identity-service/src/prisma/generated
ENV NODE_ENV=production
CMD ["sh", "-c", "npx prisma migrate deploy --schema=apps/identity-service/prisma/schema.prisma && node dist/apps/identity-service/main"]
