# ── Gateway ──────────────────────────────────────────────────────────────────
PORT=3010
FRONTEND_URL=http://localhost:3002
COOKIE_DOMAIN=localhost
NODE_ENV=development

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=pccl_secret_change_in_prod
JWT_EXPIRES_IN=1d

# ── NATS ─────────────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── Databases (one per service) ───────────────────────────────────────────────
IDENTITY_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/identity
LEARNING_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/learning
CERTIFICATION_DATABASE_URL=postgresql://postgres:postgres@localhost:5435/certification

# ── Cloudinary (portadas, documentos y videos de lección —
#    POST /uploads/image | /uploads/document | /uploads/video) ────────────────
# Crea una cuenta gratis en https://cloudinary.com y copia estos 3 valores
# desde tu Dashboard. Sin ellos, la subida de archivos falla.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
