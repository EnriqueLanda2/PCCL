{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/gateway/src",
  "monorepo": true,
  "root": "apps/gateway",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true
  },
  "projects": {
    "gateway": {
      "type": "application",
      "root": "apps/gateway",
      "entryFile": "main",
      "sourceRoot": "apps/gateway/src",
      "compilerOptions": { "tsConfigPath": "apps/gateway/tsconfig.app.json" }
    },
    "identity-service": {
      "type": "application",
      "root": "apps/identity-service",
      "entryFile": "main",
      "sourceRoot": "apps/identity-service/src",
      "compilerOptions": { "tsConfigPath": "apps/identity-service/tsconfig.app.json" }
    },
    "learning-service": {
      "type": "application",
      "root": "apps/learning-service",
      "entryFile": "main",
      "sourceRoot": "apps/learning-service/src",
      "compilerOptions": { "tsConfigPath": "apps/learning-service/tsconfig.app.json" }
    },
    "certification-service": {
      "type": "application",
      "root": "apps/certification-service",
      "entryFile": "main",
      "sourceRoot": "apps/certification-service/src",
      "compilerOptions": { "tsConfigPath": "apps/certification-service/tsconfig.app.json" }
    },
    "contracts": {
      "type": "library",
      "root": "libs/contracts",
      "entryFile": "index",
      "sourceRoot": "libs/contracts/src",
      "compilerOptions": { "tsConfigPath": "libs/contracts/tsconfig.lib.json" }
    },
    "messaging": {
      "type": "library",
      "root": "libs/messaging",
      "entryFile": "index",
      "sourceRoot": "libs/messaging/src",
      "compilerOptions": { "tsConfigPath": "libs/messaging/tsconfig.lib.json" }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": { "tsConfigPath": "libs/common/tsconfig.lib.json" }
    }
  }
}
