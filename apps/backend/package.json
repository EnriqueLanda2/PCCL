{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:gateway": "nest build gateway",
    "build:identity": "nest build identity-service",
    "build:learning": "nest build learning-service",
    "build:certification": "nest build certification-service",
    "build:all": "npm run build:gateway && npm run build:identity && npm run build:learning && npm run build:certification",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "prisma:generate:identity": "prisma generate --schema=apps/identity-service/prisma/schema.prisma",
    "prisma:generate:learning": "prisma generate --schema=apps/learning-service/prisma/schema.prisma",
    "prisma:generate:certification": "prisma generate --schema=apps/certification-service/prisma/schema.prisma",
    "prisma:generate:all": "npm run prisma:generate:identity && npm run prisma:generate:learning && npm run prisma:generate:certification",
    "prisma:migrate:identity": "prisma migrate dev --schema=apps/identity-service/prisma/schema.prisma",
    "prisma:migrate:learning": "prisma migrate dev --schema=apps/learning-service/prisma/schema.prisma",
    "prisma:migrate:certification": "prisma migrate dev --schema=apps/certification-service/prisma/schema.prisma",
    "start:gateway": "nest start gateway --watch",
    "start:identity": "nest start identity-service --watch",
    "start:learning": "nest start learning-service --watch",
    "start:certification": "nest start certification-service --watch",
    "start:gateway:prod": "node dist/apps/gateway/main",
    "start:identity:prod": "node dist/apps/identity-service/main",
    "start:learning:prod": "node dist/apps/learning-service/main",
    "start:certification:prod": "node dist/apps/certification-service/main",
    "docker:up": "docker-compose up --build",
    "docker:down": "docker-compose down",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "^2.0.5",
    "@nestjs/microservices": "^11.1.27",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/client": "^6.0.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.6",
    "helmet": "^7.1.0",
    "nats": "^2.29.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "useragent": "^2.3.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/passport": "^1.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.0.0",
    "@types/useragent": "^2.3.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^6.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "roots": [
      "<rootDir>/apps",
      "<rootDir>/libs"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "apps/**/*.(t|j)s",
      "libs/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "@app/contracts/(.*)": "<rootDir>/libs/contracts/src/$1",
      "@app/contracts": "<rootDir>/libs/contracts/src",
      "@app/messaging/(.*)": "<rootDir>/libs/messaging/src/$1",
      "@app/messaging": "<rootDir>/libs/messaging/src",
      "@app/common/(.*)": "<rootDir>/libs/common/src/$1",
      "@app/common": "<rootDir>/libs/common/src"
    }
  }
}
