generator client {
  provider = "prisma-client-js"
  output   = "../src/prisma/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("CERTIFICATION_DATABASE_URL")
}

model Certificate {
  id                String    @id @default(uuid()) @db.Uuid
  transactionDate   DateTime  @default(now()) @map("transaction_date") @db.Timestamp(6)
  startDate         DateTime? @map("start_date") @db.Timestamp(6)
  endDate           DateTime? @map("end_date") @db.Timestamp(6)
  createdBy         String?   @map("created_by") @db.VarChar(100)
  updatedBy         String?   @map("updated_by") @db.VarChar(100)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  inscriptionId     String    @map("inscription_id") @db.Uuid
  certificateNumber String    @unique @map("certificate_number") @db.VarChar(100)
  issuedAt          DateTime  @map("issued_at") @db.Timestamp(6)
  expiresAt         DateTime? @map("expires_at") @db.Timestamp(6)
  status            String    @default("valid") @db.VarChar(20)
  pdfUrl            String?   @map("pdf_url") @db.Text

  @@map("certificates")
}

model AuditLog {
  id              String    @id @default(uuid()) @db.Uuid
  transactionDate DateTime  @default(now()) @map("transaction_date") @db.Timestamp(6)
  startDate       DateTime? @map("start_date") @db.Timestamp(6)
  endDate         DateTime? @map("end_date") @db.Timestamp(6)
  createdBy       String?   @map("created_by") @db.VarChar(100)
  updatedBy       String?   @map("updated_by") @db.VarChar(100)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)
  method          String    @db.VarChar(12)
  endpoint        String    @db.VarChar(255)
  transactionType String    @map("transaction_type") @db.VarChar(30)
  actorScope      String    @default("anonymous") @map("actor_scope") @db.VarChar(20)
  actorIdentifier String?   @map("actor_identifier") @db.VarChar(140)
  browser         String?   @db.VarChar(150)
  description     String    @db.Text
  statusCode      Int?      @map("status_code")

  @@map("audit_logs")
}
